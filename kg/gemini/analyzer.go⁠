// ThreatVerdict is the structured output we force Gemini to provide
type ThreatVerdict struct {
	IsMalicious bool    `json:"is_malicious"`
	Confidence  float64 `json:"confidence"`
	Reasoning   string  `json:"reasoning"`
}

func Analyze(payload schema.TelemetryPayload) (*ThreatVerdict, error) {
	ctx := context.Background()
	client, err := genai.NewClient(ctx, option.WithAPIKey(os.Getenv("GEMINI_API_KEY")))
	if err != nil {
		return nil, err
	}
	defer client.Close()

	model := client.GenerativeModel("gemini-1.5-pro")
	model.ResponseMIMEType = "application/json" // Force structured output

	prompt := fmt.Sprintf(`Analyze the following security event:
	Event Type: %s
	Data: %s
	
	Return a JSON object with: 
	- is_malicious (boolean)
	- confidence (0.0 to 1.0)
	- reasoning (string: brief explanation)`, payload.EventType, payload.Data)

	resp, err := model.GenerateContent(ctx, genai.Text(prompt))
	// ... unmarshal resp into ThreatVerdict ...
	return verdict, nil
}
