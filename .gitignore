# ------------------------------------------------------------------------------
# Go & Build Artifacts
# ------------------------------------------------------------------------------
# Ignore compiled binaries (assuming 'mon-agent' and 'mon-worker' output names)
mon-agent
mon-worker
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# Go workspace file
go.work
go.work.sum

# ------------------------------------------------------------------------------
# Secrets & Environment Variables (CRITICAL)
# ------------------------------------------------------------------------------
# Ignore local environment files containing API keys and database credentials
.env
.env.*
!.env.example
*.pem
*.key
*.cert
*.p12

# Ignore any encrypted sovereign state or Black Folder payload staging
/blackfolder/
*.encrypted
*.gpg

# ------------------------------------------------------------------------------
# IDEs & Editors
# ------------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ------------------------------------------------------------------------------
# Logs & Telemetry Data
# ------------------------------------------------------------------------------
*.log
/logs/
/data/

# Ignore local queue or database dumps
*.rdb
*.sqlite
*.db
